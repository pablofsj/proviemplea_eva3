    "components": {
        "schemas": {
            "CandidatoPublico": {
                "title": "Candidato público",
                "description": "Respuesta pública del candidato usando CV ciego. No incluye nombre, email, teléfono, edad, género ni comuna.",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "nivel_educacional": {
                        "type": "string",
                        "example": "Técnico Nivel Superior"
                    },
                    "experiencia_laboral": {
                        "type": "string",
                        "example": "3 años en soporte técnico"
                    },
                    "habilidades": {
                        "type": "string",
                        "example": "PHP, Laravel, MySQL"
                    },
                    "certificaciones": {
                        "type": "string",
                        "example": "Certificación Desarrollo Backend"
                    },
                    "referencias": {
                        "type": "string",
                        "example": "Referencia laboral disponible"
                    },
                    "estado": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "CandidatoRequest": {
                "title": "Crear candidato",
                "required": [
                    "nombre",
                    "email",
                    "nivel_educacional",
                    "experiencia_laboral",
                    "habilidades"
                ],
                "properties": {
                    "nombre": {
                        "type": "string",
                        "example": "Juan Pérez"
                    },
                    "email": {
                        "type": "string",
                        "example": "juan@test.cl"
                    },
                    "telefono": {
                        "type": "string",
                        "example": "+56911111111"
                    },
                    "edad": {
                        "type": "integer",
                        "example": 28
                    },
                    "genero": {
                        "type": "string",
                        "example": "Masculino"
                    },
                    "comuna_residencia": {
                        "type": "string",
                        "example": "Providencia"
                    },
                    "nivel_educacional": {
                        "type": "string",
                        "example": "Universitario completo"
                    },
                    "experiencia_laboral": {
                        "type": "string",
                        "example": "3 años como desarrollador backend"
                    },
                    "habilidades": {
                        "type": "string",
                        "example": "PHP, Laravel, MySQL"
                    },
                    "certificaciones": {
                        "type": "string",
                        "example": "AWS Practitioner"
                    },
                    "referencias": {
                        "type": "string",
                        "example": "Empresa ABC"
                    }
                },
                "type": "object"
            },
            "Empresa": {
                "title": "Empresa",
                "required": [
                    "rut_empresa",
                    "nombre_empresa",
                    "rubro",
                    "email_contacto"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "rut_empresa": {
                        "type": "string",
                        "example": "76.123.456-7"
                    },
                    "nombre_empresa": {
                        "type": "string",
                        "example": "Tech Solutions"
                    },
                    "rubro": {
                        "type": "string",
                        "example": "Tecnología"
                    },
                    "email_contacto": {
                        "type": "string",
                        "example": "rrhh@techsolutions.cl"
                    },
                    "telefono": {
                        "type": "string",
                        "example": "+56222222222"
                    },
                    "beneficios": {
                        "type": "string",
                        "example": "Seguro complementario, trabajo remoto"
                    },
                    "estado": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "EmpresaCandidato": {
                "title": "Empresa Candidato",
                "required": [
                    "empresa_id",
                    "candidato_id",
                    "cargo_buscado"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "empresa_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "candidato_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "cargo_buscado": {
                        "type": "string",
                        "example": "Backend Developer"
                    },
                    "estado_proceso": {
                        "type": "string",
                        "example": "Pendiente"
                    },
                    "observacion": {
                        "type": "string",
                        "example": "Perfil interesante para entrevista"
                    }
                },
                "type": "object"
            }
        }
